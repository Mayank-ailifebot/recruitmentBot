{
  "name": "recruitbot",
  "version": "0.1.0",
  "private": true,
  "description": "RecruitBot — An End-to-End Agentic Recruitment Orchestrator",
  "scripts": {
    "dev": "concurrently -n \"API,WEB\" -c \"yellow,cyan\" \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && ../.venv/bin/uvicorn app.main:app --reload --port 8000",
    "build": "cd frontend && npm run build",
    "start": "cd backend && ../.venv/bin/uvicorn app.main:app --port 8000"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
